#!/usr/bin/env bash
# Standalone entrypoint for ai-stack (Docker + generated MCP config). No Nix required.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export AI_STACK_DIR="${AI_STACK_DIR:-$ROOT}"
SCRIPTS="$AI_STACK_DIR/scripts"

usage() {
  cat <<'EOF'
Usage: ai-stack <command> [options]

Commands:
  doctor              Check prerequisites (docker, jq, yq, curl, uv, npx, python3)
  sync                Render MCP templates → generated/, merge Hermes MCP, apply stack-models (--no-pull), sync Ollama tags
  install [--copy] [--dry-run]
                      Symlink (default) or copy commands/agents + link generated/*.json into ~/.config
  up                  sync + docker compose up -d; then apply (with pull) + sync Ollama tags
  down                docker compose down
  bootstrap-project   Pass-through to install-skill.py bootstrap (same args after this word)

Environment:
  AI_STACK_DIR        Path to this ai-stack directory (default: directory containing bin/)

Examples:
  AI_STACK_DIR=~/nix-config/ai-stack bin/ai-stack sync
  bin/ai-stack install && bin/ai-stack up
EOF
}

doctor() {
  local missing=0
  for c in docker jq yq curl uv npx python3; do
    if command -v "$c" >/dev/null 2>&1; then
      echo "  ok: $c"
    else
      echo "  missing: $c" >&2
      missing=1
    fi
  done
  echo "  AI_STACK_DIR=$AI_STACK_DIR"
  if [[ -f "$AI_STACK_DIR/generated/opencode.json" ]]; then
    echo "  ok: generated/opencode.json exists"
  else
    echo "  hint: run 'ai-stack sync' to create generated/*.json" >&2
    missing=1
  fi
  return "$missing"
}

cmd_sync() {
  bash "$SCRIPTS/render-mcp-templates.sh"
  bash "$SCRIPTS/apply-stack-models.sh" --no-pull
  bash "$SCRIPTS/sync-opencode-ollama-models.sh"
}

cmd_up() {
  cmd_sync
  bash "$SCRIPTS/docker-compose.sh" up -d "$@"
  bash "$SCRIPTS/apply-stack-models.sh"
  bash "$SCRIPTS/sync-opencode-ollama-models.sh"
}

cmd_down() {
  bash "$SCRIPTS/docker-compose.sh" down "$@"
}

cmd_install() {
  local copy=false dry=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --copy) copy=true; shift ;;
      --dry-run) dry=true; shift ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done
  if ! $dry; then
    cmd_sync
  fi
  link_one() {
    local src="$1" dest="$2"
    if $dry; then echo "would: $src -> $dest"; return; fi
    mkdir -p "$(dirname "$dest")"
    if $copy; then cp -f "$src" "$dest"; else ln -sfn "$src" "$dest"; fi
  }
  local f
  if [[ -d "$AI_STACK_DIR/commands" ]]; then
    for f in "$AI_STACK_DIR/commands"/*.md; do
      [[ -e "$f" ]] || continue
      link_one "$f" "$HOME/.config/opencode/commands/$(basename "$f")"
    done
  fi
  if [[ -d "$AI_STACK_DIR/agents/opencode" ]]; then
    for f in "$AI_STACK_DIR/agents/opencode"/*.md; do
      [[ -e "$f" ]] || continue
      link_one "$f" "$HOME/.config/opencode/agents/$(basename "$f")"
    done
  fi
  if ! $dry; then
    mkdir -p "$HOME/.config/opencode"
    link_one "$AI_STACK_DIR/generated/opencode.json" "$HOME/.config/opencode/opencode.json"
  fi
  echo "ai-stack install: done (copy=$copy dry_run=$dry)"
}

main() {
  local cmd="${1:-}"
  [[ -n "$cmd" ]] || { usage; exit 1; }
  shift || true
  case "$cmd" in
    doctor) doctor "$@" ;;
    sync) cmd_sync "$@" ;;
    install) cmd_install "$@" ;;
    up) cmd_up "$@" ;;
    down) cmd_down "$@" ;;
    bootstrap-project)
      exec python3 "$AI_STACK_DIR/scripts/install-skill.py" bootstrap "$@"
      ;;
    -h|--help|help) usage; exit 0 ;;
    *) echo "Unknown command: $cmd" >&2; usage >&2; exit 1 ;;
  esac
}

main "$@"