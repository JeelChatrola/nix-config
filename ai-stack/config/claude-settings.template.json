{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:11434",
    "ANTHROPIC_AUTH_TOKEN": "ollama",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ruff *)",
      "Bash(clang-format *)",
      "Bash(clang-tidy *)",
      "Bash(cmake *)",
      "Bash(make *)",
      "Bash(ninja *)",
      "Bash(bear *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(uv *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(tree *)"
    ]
  },
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@0.6.3"],
      "description": "Persistent knowledge graph across sessions (pinned; mutable runtime via npx)"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@0.6.2"],
      "description": "Structured multi-step reasoning tool (pinned)"
    },
    "searxng": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "searxng-mcp-server",
        "--searxng-url",
        "__SEARXNG_URL__"
      ],
      "description": "Web search via local SearXNG; URL from SEARXNG_PORT in ai-stack/.env (render-mcp-templates.sh)"
    },
    "code-review-graph": {
      "command": "uv",
      "args": ["tool", "run", "--from", "code-review-graph", "code-review-graph", "serve"],
      "description": "Tree-sitter code graph MCP (uv tool install code-review-graph)"
    },
    "arxiv": {
      "command": "uv",
      "args": ["tool", "run", "arxiv-mcp-server"],
      "description": "arXiv MCP (uv tool install arxiv-mcp-server)"
    }
  }
}
