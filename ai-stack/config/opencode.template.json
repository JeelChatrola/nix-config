{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {}
    },
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM (HF)",
      "options": {
        "baseURL": "http://localhost:8000/v1",
        "apiKey": "dummy"
      },
      "models": {
        "Qwen/Qwen2.5-3B-Instruct": {
          "name": "Qwen2.5 3B Instruct (vLLM)"
        }
      }
    }
  },
  "mcp": {
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory@0.6.3"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@0.6.2"
      ]
    },
    "searxng": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "searxng-mcp-server",
        "--searxng-url",
        "__SEARXNG_URL__"
      ]
    },
    "code-review-graph": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "--from",
        "code-review-graph",
        "code-review-graph",
        "serve"
      ]
    },
    "arxiv": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "arxiv-mcp-server"
      ]
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "gh *": "allow",
      "ruff *": "allow",
      "clang-format *": "allow",
      "clang-tidy *": "allow",
      "cmake *": "allow",
      "make *": "allow",
      "ninja *": "allow",
      "bear *": "allow",
      "pytest *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "uv *": "allow",
      "docker *": "allow",
      "docker-compose *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "tree *": "allow"
    },
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "codesearch": "allow"
  }
}
