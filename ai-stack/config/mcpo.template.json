{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@0.6.3"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@0.6.2"]
    },
    "searxng": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "searxng-mcp-server",
        "--searxng-url",
        "__SEARXNG_URL__"
      ]
    },
    "code-review-graph": {
      "command": "uv",
      "args": ["tool", "run", "--from", "code-review-graph", "code-review-graph", "serve"]
    },
    "arxiv": {
      "command": "uv",
      "args": ["tool", "run", "arxiv-mcp-server"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@3.0.0"]
    },
    "deepwiki": {
      "type": "streamable-http",
      "url": "https://mcp.deepwiki.com/mcp"
    }
  }
}
