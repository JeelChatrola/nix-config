# Copy to ai-stack/.env (gitignored). Used by docker compose for Ollama and SearXNG.

# deploy.sh --ai: set to 0 to skip Docker (Ollama, SearXNG) but still install
# jeel-ai (opencode, MCP configs, skills/agents). Start Docker anytime with ai-up.
# AI_STACK_DOCKER=0

# Host port for SearXNG; bin/ai-stack sync and render-mcp-templates.sh build MCP URLs from this.
# SEARXNG_PORT=8080
# SEARXNG_SECRET=***

# Gated Ollama / HF models (Ollama container)
# HF_TOKEN=***

# Ollama model list: edit ai-stack/stack-models.json (ollama.pull[]), then run:
#   bash ai-stack/scripts/apply-stack-models.sh
# ai-up / ./deploy.sh --ai / bin/ai-stack sync run the render + apply pipeline.

# Not read by Docker — put in your shell for MCP + CLI agents on the host
# ANTHROPIC_API_KEY=***    # OpenCode cloud models
# CONTEXT7_API_KEY=***     # Optional higher Context7 MCP rate limits

# Optional skill (export in shell, not necessarily here)
# ALPHAXIV_API_KEY=***