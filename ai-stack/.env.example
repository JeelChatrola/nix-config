# Copy to ai-stack/.env (gitignored). Used by docker compose for Lobe + Ollama.

# deploy.sh --ai: set to 0 to skip the whole Docker stack (Ollama, Lobe, SearXNG) but still
# install jeel-ai (opencode, claude, MCP configs, skills/agents). Start Docker anytime with ai-up.
# AI_STACK_DOCKER=0

LOBE_PORT=3210
# Host port for SearXNG; `bin/ai-stack sync` / `scripts/render-mcp-templates.sh` builds MCP URLs from this (see config/*.template.json).
# SEARXNG_PORT=8080
# Shared with Lobe + Docker SearXNG (rendered into searxng-settings.yml) and Hermes web search (SEARXNG_URL in ~/.hermes/.env).
# SEARXNG_SECRET=...

# --- Optional: only if you use these features ---

# Gated Ollama / HF models (Ollama container) and vLLM (Hugging Face Hub)
# HF_TOKEN=hf_...

# --- vLLM + Ollama model lists ---
# Edit ai-stack/stack-models.json (ollama.pull[], vllm.*), then run:
#   bash ai-stack/scripts/apply-stack-models.sh
# That writes ai-stack/models.compose.env (gitignored) and updates provider.vllm in generated/opencode.json.
# `ai-up` / `./deploy.sh --ai` / `bin/ai-stack sync` run the render + apply pipeline for you.

# LobeChat hosted providers (names vary by Lobe version; set in UI too if needed)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Not read by Docker: put in your shell for MCP + CLI agents on the host
# ANTHROPIC_API_KEY=...    # Claude Code cloud OR OpenCode — see ai-stack/README.md
# CONTEXT7_API_KEY=...     # Optional higher Context7 MCP rate limits

# Optional skill (export in shell, not necessarily here)
# ALPHAXIV_API_KEY=...
