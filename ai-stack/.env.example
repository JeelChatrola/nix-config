# Copy this file to .env to override defaults.
# The .env file is gitignored so secrets are never committed.

LOBE_PORT=3210

# Optional: Hugging Face token for gated Ollama models
# HF_TOKEN=hf_...

# Optional: cloud model providers (configure in LobeChat UI after adding here)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
