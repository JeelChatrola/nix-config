{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:11434",
    "ANTHROPIC_AUTH_TOKEN": "ollama",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ruff *)",
      "Bash(clang-format *)",
      "Bash(clang-tidy *)",
      "Bash(cmake *)",
      "Bash(make *)",
      "Bash(ninja *)",
      "Bash(bear *)",
      "Bash(pytest *)",
      "Bash(python *)",
      "Bash(uv *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(tree *)"
    ]
  },
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Persistent knowledge graph across sessions"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Structured multi-step reasoning tool"
    },
    "searxng": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "searxng-mcp-server",
        "--searxng-url",
        "http://127.0.0.1:8080"
      ],
      "description": "Web search + fetch via local SearXNG (docker: SEARXNG_PORT default 8080; uv tool install searxng-mcp-server)"
    },
    "code-review-graph": {
      "command": "uv",
      "args": ["tool", "run", "--from", "code-review-graph", "code-review-graph", "serve"],
      "description": "Tree-sitter code graph + blast-radius review context (uv tool install code-review-graph)"
    },
    "arxiv": {
      "command": "uv",
      "args": ["tool", "run", "arxiv-mcp-server"],
      "description": "Search, download, read arXiv papers (uv tool install arxiv-mcp-server). Storage: ~/.arxiv-mcp-server/papers or ARXIV_STORAGE_PATH"
    }
  }
}
