{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder:30b-a3b-q4_K_M": {
          "name": "Qwen3 Coder 30B-A3B — best coder, 578 tok/s, 262k ctx"
        },
        "gpt-oss:20b": {
          "name": "GPT-OSS 20B — dense 20B, 272 tok/s, 131k ctx"
        },
        "deepseek-coder-v2:16b-lite-instruct-q4_K_M": {
          "name": "DeepSeek Coder V2 Lite — 451 tok/s, 164k ctx"
        },
        "qwen2.5-coder:7b-instruct": {
          "name": "Qwen2.5 Coder 7B — workhorse Q8_0, 65 tok/s, 32k ctx"
        },
        "alibayram/mimo-7b-rl": {
          "name": "MiMo 7B RL — reasoning + code specialist, 70 tok/s"
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "gh *": "allow",
      "ruff *": "allow",
      "clang-format *": "allow",
      "clang-tidy *": "allow",
      "cmake *": "allow",
      "make *": "allow",
      "ninja *": "allow",
      "bear *": "allow",
      "pytest *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "uv *": "allow",
      "docker *": "allow",
      "docker-compose *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "tree *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "nix *": "allow"
    },
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "codesearch": "allow"
  }
}
