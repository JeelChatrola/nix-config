{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.5:35b-a3b-q4_K_M": {
          "name": "qwen3.5:35b-a3b-q4_K_M"
        },
        "hf.co/Qwen/Qwen3-14B-GGUF:Q5_K_M": {
          "name": "hf.co/Qwen/Qwen3-14B-GGUF:Q5_K_M"
        },
        "qwen3-coder:30b-a3b-q4_K_M": {
          "name": "Qwen3 Coder 30B-A3B — best coder, 578 tok/s, 262k ctx"
        }
      }
    }
  },
  "mcp": {
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "searxng": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "searxng-mcp-server",
        "--searxng-url",
        "http://127.0.0.1:8080"
      ]
    },
    "code-review-graph": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "--from",
        "code-review-graph",
        "code-review-graph",
        "serve"
      ]
    },
    "arxiv": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "arxiv-mcp-server"
      ]
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "gh *": "allow",
      "ruff *": "allow",
      "clang-format *": "allow",
      "clang-tidy *": "allow",
      "cmake *": "allow",
      "make *": "allow",
      "ninja *": "allow",
      "bear *": "allow",
      "pytest *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "uv *": "allow",
      "docker *": "allow",
      "docker-compose *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "tree *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "nix *": "allow"
    },
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "codesearch": "allow"
  }
}
