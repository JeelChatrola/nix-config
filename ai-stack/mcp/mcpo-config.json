{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "searxng": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "searxng-mcp-server",
        "--searxng-url",
        "http://127.0.0.1:8080"
      ]
    },
    "code-review-graph": {
      "command": "uv",
      "args": ["tool", "run", "--from", "code-review-graph", "code-review-graph", "serve"]
    },
    "arxiv": {
      "command": "uv",
      "args": ["tool", "run", "arxiv-mcp-server"]
    }
  }
}
