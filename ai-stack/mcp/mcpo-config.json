{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"]
    },
    "code-review-graph": {
      "command": "uv",
      "args": ["tool", "run", "--from", "code-review-graph", "code-review-graph", "serve"]
    },
    "arxiv": {
      "command": "uv",
      "args": ["tool", "run", "arxiv-mcp-server"]
    }
  }
}
