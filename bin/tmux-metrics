set -euo pipefail

cpu_usage=$(
  LC_ALL=C top -bn1 2>/dev/null |
    awk '/^%?Cpu/ { printf "%.0f", 100 - $8; exit }'
)
printf ' CPU %s%%' "${cpu_usage:-?}"

if command -v nvidia-smi >/dev/null 2>&1; then
  gpu_usage=$(
    nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null |
      awk 'NF { total += $1; count++ } END { if (count) printf "%.0f", total / count }'
  )
  if [[ -n "$gpu_usage" ]]; then
    printf '  󰢮 GPU %s%%' "$gpu_usage"
  fi
fi
