#!/usr/bin/env bash
# nix-refresh — rebuild home-manager config from anywhere.
# Usage: nix-refresh           # base config (no AI)
#        nix-refresh --ai      # base + AI stack; restarts Hermes gateway when installed
#        nix-refresh --ai --no-docker  # AI without Docker (gateway still restarted)
#        nix-refresh --user LOGIN     # override username
set -euo pipefail

NIX_CONFIG="${NIX_CONFIG_DIR:-$HOME/nix-config}"

if [[ ! -d "$NIX_CONFIG/deploy.sh" ]] && [[ ! -f "$NIX_CONFIG/deploy.sh" ]]; then
  echo "nix-refresh: $NIX_CONFIG not found. Set NIX_CONFIG_DIR or clone nix-config to ~/nix-config." >&2
  exit 1
fi

exec bash "$NIX_CONFIG/deploy.sh" "$@"