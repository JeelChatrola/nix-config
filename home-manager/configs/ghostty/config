# Ghostty — normal terminal interaction (context menu, explicit copy/paste).
# Install Ghostty via system-setup: ./install.sh ghostty (apt or PPA)

font-family = JetBrainsMono Nerd Font
font-size = 11

window-padding-x = 6
window-padding-y = 6

# Right-click opens context menu (not forced paste).
right-click-action = context-menu
copy-on-select = false

# Avoid fighting tmux/shell title updates.
shell-integration-features = no-title,ssh-env,ssh-terminfo

keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_clipboard
