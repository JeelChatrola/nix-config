# Ignore Nix build artifacts and temporary files
result
.direnv
.envrc

# Ignore backup files
*.backup
*.bak
*.tmp

# Ignore editor files
*~
.*.swp
.*.swo
.vscode/
.idea/
__pycache__/

# Ignore OS files
.DS_Store
Thumbs.db

# AI stack secrets - never commit API keys
ai-stack/.env

# AI stack generated at runtime (MCP JSON, compose env from stack-models)
ai-stack/generated/
ai-stack/models.compose.env
